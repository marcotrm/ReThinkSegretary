# Copia in .env per lo sviluppo locale. NON committare .env (è in .gitignore).
# Su Railway questi valori si impostano come Variables del servizio.

# Postgres. Se assente, il servizio usa lo storage IN MEMORIA (dati persi al riavvio).
# Su Railway: aggiungi il plugin Postgres e referenzia ${{Postgres.DATABASE_URL}}
DATABASE_URL=

# Chiave condivisa richiesta nell'header X-API-Key da n8n e dall'Agent ElevenLabs.
# Se vuota, il servizio parte SENZA autenticazione (solo per il locale).
# Generane una con: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=

# Percorso della config multi-tenant. Default: config/clienti.json nella root del repo.
CLIENTI_CONFIG_PATH=

LOG_LEVEL=INFO
