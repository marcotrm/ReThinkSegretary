# Env dell'assistente Telegram (Fase 1). Copiare in prod.env e riempire.
# TELEGRAM_BOT_TOKEN e GROQ_API_KEY sono gli STESSI del container principale
# (si trovano in /opt/quisvapo-voicebot/prod.env).

TELEGRAM_BOT_TOKEN=            # token di @QuisvapoBot (dal prod.env del bot principale)
GROQ_API_KEY=                 # chiave Groq (meglio la Dev dedicata: il free tier ha 12k token/min)
GROQ_MODEL=llama-3.3-70b-versatile
ELEVENLABS_API_KEY=          # per leggere le telefonate della voce (sk_...)
ELEVEN_AGENT_ID=agent_2201ky21r7vqe329fd186nwmaees
BOT_API_URL=https://bot-api.quisvapo.app
BOT_API_KEY=                 # X-API-Key dei tool cerca/negozi (== API_KEY del bot principale)
ALLOWED_USERNAME=MannaccBudd
